from api_client import APIClient
from logger import log
import config

class Order:
    """
    실제로 주식을 '사거나(Buy)', '파는(Sell)' 행동을 전담하는 클래스입니다.
    돈이 걸려있는 가장 중요한 곳입니다.
    """
    def __init__(self, token):
        self.client = APIClient(token)
        # 매수(살 때)와 매도(팔 때)의 TR_ID 암호코드가 다릅니다!
        self.buy_tr_id = "VTTC0802U"  # 현금 매수 (모의투자용)
        self.sell_tr_id = "VTTC0801U" # 현금 매도 (모의투자용)
        self.endpoint = "/uapi/domestic-stock/v1/trading/order-cash" # 주문용 API 주소

    def _place_order(self, tr_id, symbol, price, qty):
        """
        매수와 매도는 방향만 다를 뿐, 보내는 정보의 형식은 똑같습니다.
        그래서 중복 코드를 줄이기 위해 내부적으로 사용하는 공통 주문 함수를 만들었습니다.
        """
        # 서버에 넘겨줄 '주문서' 내용입니다.
        payload = {
            "CANO": config.CANO,
            "ACNT_PRDT_CD": config.ACNT_PRDT_CD,
            "PDNO": symbol,               # 살 주식 종목코드 (삼성전자)
            "ORD_DVSN": "00",             # 00: 지정가 (내가 정한 가격에 사겠다)
            "ORD_QTY": str(qty),          # 수량 (API가 문자열을 요구하므로 str로 감쌉니다)
            "ORD_UNPR": str(price)        # 가격 (API가 문자열을 요구하므로 str로 감쌉니다)
        }

        # 주문은 데이터를 변경하는 행위이므로 GET이 아닌 POST 방식을 사용합니다.
        data = self.client.request("POST", self.endpoint, tr_id=tr_id, payload=payload)
        
        # rt_cd가 "0"이면 주문이 증권사 서버에 정상 접수된 것입니다.
        if data and data.get("rt_cd") == "0":
            log.info(f"주문이 정상적으로 접수되었습니다. [응답 메시지: {data.get('msg1')}]")
            return True
        else:
            msg = data.get("msg1", "알 수 없는 에러") if data else "응답 없음"
            log.error(f"주문 접수 실패: {msg}")
            return False

    def buy(self, symbol, price, qty=1):
        """매수 버튼 역할입니다."""
        log.info(f"🟢 [매수 주문 요청] 종목:{symbol}, 가격:{price}원, 수량:{qty}주")
        return self._place_order(self.buy_tr_id, symbol, price, qty)

    def sell(self, symbol, price, qty=1):
        """매도 버튼 역할입니다."""
        log.info(f"🔴 [매도 주문 요청] 종목:{symbol}, 가격:{price}원, 수량:{qty}주")
        return self._place_order(self.sell_tr_id, symbol, price, qty)
