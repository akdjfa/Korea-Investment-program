# ==============================================================================
# 프로그램 환경 설정 모듈 (Config)
# 이 파일은 봇이 작동하는 데 필요한 각종 '비밀번호'와 '기본 세팅값'을 모아둔 곳입니다.
# 다른 모든 파일(main, trader, account 등)이 이 파일을 참조하여 움직입니다.
# ==============================================================================

import os # 운영체제(OS)와 상호작용하기 위한 기본 라이브러리입니다. (환경변수를 읽을 때 사용)

# ==============================================================================
# 1. 환경 변수 로드 및 중요 정보 세팅
# ==============================================================================
# [중요] 코드 파일(config.py) 안에 진짜 내 계좌번호나 비밀키를 텍스트로 적어두고 
# 깃허브(Github) 등에 올리면 전 세계 해커들에게 내 지갑을 열어주는 꼴이 됩니다.
# 따라서 컴퓨터 깊숙한 곳(환경 변수)에 숨겨둔 값을 os.environ.get()으로 몰래 꺼내옵니다.
# 괄호 안의 두 번째 값("")은 "만약 값을 못 찾으면 빈칸으로 둬라"는 뜻입니다.

# [하자 보수 완료] 사용자가 "12345678-01" 처럼 하이픈(-)을 섞어 적을 경우를 대비하여
# .replace("-", "") 를 추가해 숫자만 남도록 깔끔하게 정제합니다.
raw_account = os.environ.get("GH_ACCOUNT", "").replace("-", "")

APP_KEY = os.environ.get("GH_APPKEY", "")
APP_SECRET = os.environ.get("GH_APPSECRET", "")

# 한국투자증권 API는 10자리 계좌번호를 통째로 쓰지 않고, 
# '앞 8자리'와 '뒤 2자리'로 나누어서 요구하는 까다로운 규칙이 있습니다.

# CANO: 종합계좌번호 (앞 8자리)
# 문자열 슬라이싱 [:8]을 이용해 정제된 계좌번호의 처음부터 8번째 글자까지 잘라냅니다.
CANO = raw_account[:8] if len(raw_account) >= 8 else ""

# ACNT_PRDT_CD: 계좌상품코드 (뒤 2자리)
# 보통 주식계좌는 '01'입니다. 문자열 슬라이싱 [8:]을 이용해 9번째 글자부터 끝까지 잘라냅니다.
# 만약 사용자가 앞 8자리만 입력했다면, 자동으로 주식계좌 기본값인 "01"을 쓰도록 설정했습니다.
ACNT_PRDT_CD = raw_account[8:] if len(raw_account) >= 10 else "01"


