from auth import get_auth_token # 토큰 발급 함수 가져오기
from trader import AutoTrader   # 메인 봇 가져오기
from logger import log          # 로거 가져오기
import config                   # 환경변수 설정 가져오기
import sys                      # 시스템 종료 기능

def check_env():
    """
    프로그램이 켜지자마자 실행되는 함수입니다.
    우리가 Codespaces 환경변수(비밀번호 등)를 제대로 입력했는지 검사합니다.
    """
    if not config.ACCOUNT_NO or not config.APP_KEY or not config.APP_SECRET:
        log.error("환경 변수가 비어있습니다! GH_ACCOUNT, GH_APPKEY, GH_APPSECRET 설정이 반드시 필요합니다.")
        sys.exit(1) # 세팅이 안 되어있으면 프로그램을 강제로 종료시킵니다.

def main():
    """프로그램이 가장 먼저 실행하는 본문(Main)입니다."""
    log.info("--- 자동매매 프로그램을 켭니다 ---")
    check_env() # 세팅 검사

    # 1. API 접속 권한(토큰)부터 받아옵니다.
    token = get_auth_token()
    if not token:
        log.error("토큰 발급에 실패하여 프로그램을 종료합니다.")
        sys.exit(1) # 토큰이 없으면 한국투자증권과 통신할 수 없으니 종료합니다.

    # 2. 로봇(AutoTrader)을 조립하고 토큰을 쥐여줍니다.
    trader = AutoTrader(token)
    
    try:
        # 3. 로봇 전원 켜기 (무한 루프 시작)
        trader.run()
        
    except KeyboardInterrupt:
        # 사용자가 키보드로 강제 종료(Ctrl+C)를 눌렀을 때 예쁘게 꺼지게 하는 마법의 코드입니다.
        log.info("사용자가 강제로 프로그램을 종료했습니다. (안전하게 꺼집니다)")
        
    except Exception as e:
        # 그 외에 우리가 예상하지 못한 에러(인터넷 끊김, 컴퓨터 고장 등)가 나면 로그에 남깁니다.
        log.error(f"예기치 못한 런타임 오류가 발생했습니다: {e}")

# 파이썬만의 독특한 문법입니다. 
# "만약 이 main.py 파일이 누군가에게 import된 게 아니라, 사용자가 직접 실행(python main.py)했다면 아래를 실행해라"라는 뜻입니다.
if __name__ == "__main__":
    main()
