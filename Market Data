from api_client import APIClient
from logger import log

class MarketData:
    """
    이 클래스는 주식 시장 데이터(예: 삼성전자 현재가)를 조회하는 역할만 전담합니다.
    """
    def __init__(self, token):
        # 통신을 위해 인증 토큰을 넣어서 클라이언트를 준비합니다.
        self.client = APIClient(token)
        
        # TR_ID (Transaction ID): "내가 지금 하려는 행동이 뭔지" 알려주는 일종의 암호코드입니다.
        # FHKST01010100 은 한국투자증권에서 "주식 현재가 조회"를 의미하는 모의투자 코드입니다.
        self.tr_id = "FHKST01010100" 
        
        # 현재가 조회를 위해 찾아가야 할 상세 주소입니다.
        self.endpoint = "/uapi/domestic-stock/v1/quotations/inquire-price"

    def get_current_price(self, symbol):
        """
        특정 종목코드(symbol)를 넣어주면 현재 주식 가격을 숫자로 반환해줍니다.
        """
        # API 서버에 보낼 질문(파라미터) 묶음입니다.
        params = {
            "FID_COND_MRKT_DIV_CODE": "J", # 'J'는 '주식' 시장을 의미합니다.
            "FID_INPUT_ISCD": symbol       # 조회할 종목코드 (우리의 경우 "005930")
        }
        
        # GET 방식으로 서버에 조회를 요청합니다.
        data = self.client.request("GET", self.endpoint, tr_id=self.tr_id, params=params)
        
        # 데이터가 있고, rt_cd(리턴 코드)가 "0"(정상)인 경우에만 가격을 뽑아냅니다.
        if data and data.get("rt_cd") == "0":
            try:
                # 서버가 보내준 거대한 JSON 데이터 중에서
                # 'output' 안의 'stck_prpr'(주식 현재가)라는 항목만 쏙 빼서 정수(int)로 바꿉니다.
                current_price = int(data["output"]["stck_prpr"])
                return current_price
            except (KeyError, ValueError) as e:
                log.error(f"서버 응답에서 현재가 데이터를 찾는 중 오류 발생: {e}")
        else:
            # 실패한 경우 서버가 보낸 에러 메시지를 기록합니다.
            msg = data.get("msg1", "알 수 없는 에러") if data else "응답 없음"
            log.error(f"현재가 조회 API 실패: {msg}")
            
        return None # 조회가 실패하면 아무것도 돌려주지 않습니다.
